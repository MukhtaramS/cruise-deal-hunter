# Postgres container credentials (used by docker-compose)
POSTGRES_USER=cruise
POSTGRES_PASSWORD=cruise
POSTGRES_DB=cruise

# SQLAlchemy URL. Inside docker the host is "db"; when running the app
# locally against the containerized Postgres, use "localhost" instead.
DATABASE_URL=postgresql+psycopg://cruise:cruise@db:5432/cruise

# Telegram bot (create via @BotFather). Get your chat id by messaging
# the bot /start once the bot service is running.
TELEGRAM_BOT_TOKEN=your_bot_token_here

TELEGRAM_CHAT_ID=

# Groq — only used for the LLM fallback parser and cross-portal dedup
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Deal-hunting profile: default | visa_ru | all (run both)
# default = all scrapers, no visa filter (original behavior)
# visa_ru = RU-relevant scrapers, alerts only on fully visa-free itineraries
PROFILE=all

# Scheduling / deal thresholds (defaults shown)
SCRAPE_INTERVAL_HOURS=4
HOT_DEAL_MEDIAN_RATIO=0.40
HOT_DEAL_MAX_PRICE_PER_NIGHT=60
